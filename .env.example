# Snowflake credentials are read from ~/.dbt/profiles.yml — do not add them here.

# ══════════════════════════════════════════════════════════════════════════════
# PART 1 — dbt + Snowflake transform layer
# No API keys needed. Run: dbt build --exclude mart_eval_results_summary
# ══════════════════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO

# ══════════════════════════════════════════════════════════════════════════════
# PART 2 — LangGraph agent + Streamlit chat
# Needs at least one of OPENAI_API_KEY or GOOGLE_API_KEY.
# Run: streamlit run app/streamlit_app.py
# ══════════════════════════════════════════════════════════════════════════════

# Which agent to run: openai | gemini  (overridden by --agent flag at runtime)
AGENT_NAME=openai

# OpenAI agent
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                  # or gpt-4o-mini for lower cost

# Gemini agent (free key at https://aistudio.google.com → Get API key)
GOOGLE_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash        # gemini-2.0-flash deprecated for new API users

STREAMLIT_PORT=8501

# ══════════════════════════════════════════════════════════════════════════════
# PART 3 — Claude evaluation pipeline
# Needs ANTHROPIC_API_KEY in addition to Part 2 keys.
# Run: python -m src.evaluation.pipeline --agent openai
# ══════════════════════════════════════════════════════════════════════════════

# Anthropic — LLM judge / evaluator
ANTHROPIC_API_KEY=sk-ant-...
EVAL_MODEL=claude-sonnet-4-6

# Thresholds — a run passes when both are met
EVAL_SCORE_THRESHOLD=0.75            # minimum score for a single question to pass
EVAL_PASS_RATE_THRESHOLD=0.85        # minimum fraction of questions that must pass
