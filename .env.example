# Snowflake credentials are read from ~/.dbt/profiles.yml — do not add them here.

# OpenAI — used by the LangGraph agent (Part 2)
OPENAI_API_KEY=sk-...
AGENT_MODEL=gpt-4o

# Anthropic — used by the evaluation scorer (Part 3)
ANTHROPIC_API_KEY=sk-ant-...

# Evaluation config
EVAL_MODEL=claude-sonnet-4-6
EVAL_SCORE_THRESHOLD=0.75
EVAL_PASS_RATE_THRESHOLD=0.85

# App
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
